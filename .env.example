# Configuração do PostgreSQL - Copie para .env e preencha com seus dados

# URL de conexão com PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/banco_dados
DATABASE_URL=postgresql://estoque_user:sua_senha_segura@seu-ip-servidor:5432/estoque_db

# Exemplos:
# Servidor local: postgresql://estoque_user:12345@localhost:5432/estoque_db
# Servidor remoto: postgresql://estoque_user:12345@192.168.1.100:5432/estoque_db

# Ambiente da aplicação
FLASK_ENV=production

# Chave secreta para sessões (gere uma string aleatória segura)
SECRET_KEY=sua-chave-secreta-muito-segura-aqui
